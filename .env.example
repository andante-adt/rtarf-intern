# Copy this file to .env and fill in real values. Never commit the real .env.

# JWT auth (required) — used to sign/verify login tokens in auth.py
JWT_SECRET_KEY=change-me-to-a-long-random-string
SOC_USERNAME=admin
SOC_PASSWORD=change-me

# Telegram alert notifications (optional — only needed if telegram_sender.py is used)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
